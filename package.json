{
  "name": "what-changes",
  "description": "Report what changes within branches",
  "version": "1.0.0",
  "author": "classfunc",
  "private": true,
  "homepage": "https://github.com/ClassFunc/what-changes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClassFunc/what-changes.git"
  },
  "bugs": {
    "url": "https://github.com/ClassFunc/what-changes/issues"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript",
    "changes",
    "pr"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "jest",
    "format:write": "prettier --write **/*.js",
    "format:check": "prettier --check **/*.js",
    "lint": "npx eslint .",
    "package": "ncc build src/index.js --license licenses.txt",
    "package:watch": "npm run package -- --watch",
    "test": "(jest && make-coverage-badge --output-path ./badges/coverage.svg) || make-coverage-badge --output-path ./badges/coverage.svg",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "MIT",
  "jest": {
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ]
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^2.0.0",
    "markdown-it": "^14.3.0",
    "markdown-it-multimd-table": "^4.2.3",
    "shelljs": "^0.10.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@vercel/ncc": "^0.44.1",
    "babel-preset-jest": "^30.4.0",
    "eslint": "^10.6.0",
    "eslint-plugin-github": "^6.1.0",
    "eslint-plugin-jest": "^29.15.4",
    "jest": "^30.4.2",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.9.4"
  }
}
